.terraform/
**/.terraform/

# Local Terraform state files
*.tfstate
*.tfstate.*
*.tfbackup
*.terraform.lock.hcl

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Crash logs
crash.log
crash.*.log

# CLI configuration
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output
*.tfplan

# IDE/editor files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db